{
  "name": "alspos",
  "version": "0.1.0",
  "main": "main.js",
  "description": "alspos",
  "author": "Alston Mendonca <alstondmendonca@gmail.com>",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite & wait-on http://localhost:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "dev:vite": "vite",
    "start": "electron .",
    "build": "vite build",
    "preview": "vite preview",
    "verify:arch": "node scripts/verify-compat-shims.js",
    "verify:layout": "node scripts/verify-project-structure.js",
    "verify:structure": "npm run verify:arch && npm run verify:layout",
    "verify:syntax": "node --check src/main/main.js && node --check src/main/backup.js && node --check src/main/restore.js",
    "validate": "npm run verify:structure && npm run verify:syntax && npm run build",
    "package": "npm run build && electron-builder --dir",
    "make": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "icon": "assets/images/favicon.ico",
    "appId": "com.alspos.app",
    "productName": "alspos",
    "artifactName": "alspos Setup.exe",
    "files": [
      "main.js",
      "backup.js",
      "restore.js",
      "src/preload.js",
      "dist/**/*",
      "src/main/**/*",
      "src/resources/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "icon": "assets/images/favicon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "alspos",
      "allowElevation": false,
      "runAfterFinish": true,
      "installerIcon": "assets/images/favicon.ico",
      "uninstallerIcon": "assets/images/favicon.ico"
    }
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.0.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "node-abi": "^4.28.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.4.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "electron-store": "^8.0.2",
    "escpos": "3.0.0-alpha.6",
    "escpos-usb": "3.0.0-alpha.4",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.3",
    "tailwind-merge": "^2.3.0",
    "usb": "^1.8.8",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  }
}
