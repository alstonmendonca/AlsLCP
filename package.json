{
  "name": "lassi-corner",
  "version": "1.0.4",
  "main": "main.js",
  "description": "Lassi Corner POS System",
  "author": "Alston Mendonca <alstondmendonca@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alstonmendonca/AlsLCP.git"
  },
  "scripts": {
    "dev": "vite & wait-on http://localhost:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "dev:vite": "vite",
    "start": "electron .",
    "build": "vite build",
    "preview": "vite preview",
    "verify:compat": "node scripts/verify-compat-shims.js",
    "verify:layout": "node scripts/verify-project-structure.js",
    "verify:structure": "npm run verify:compat && npm run verify:layout",
    "validate": "npm run verify:structure",
    "package": "npm run build && electron-builder --dir",
    "make": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "icon": "assets/images/favicon.ico",
    "appId": "com.lassicorner.app",
    "productName": "Lassi Corner",
    "artifactName": "Lassi Corner Setup.exe",
    "files": [
      "dist/**/*",
      "src/main/**/*"
    ],
    "extraResources": [
      {
        "from": "src/resources",
        "to": "resources"
      }
    ],
    "win": {
      "icon": "assets/images/favicon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lassi Corner POS System",
      "allowElevation": false,
      "runAfterFinish": true,
      "installerIcon": "assets/images/favicon.ico",
      "uninstallerIcon": "assets/images/uninstall.ico"
    }
  },
  "devDependencies": {
    "@electron/packager": "^18.4.2",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.0.0",
    "electron": "^25.9.8",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "chart.js": "^4.4.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "electron-store": "^8.0.2",
    "escpos": "3.0.0-alpha.6",
    "escpos-usb": "3.0.0-alpha.4",
    "fs": "^0.0.1-security",
    "lucide-react": "^0.292.0",
    "open": "^10.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.3",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^2.3.0",
    "usb": "^1.8.8",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  }
}
